# Harvest Finance - Frontend Environment Variables

# The base URL for the Backend API (without trailing slash)
# Default for local development: http://localhost:5000/api/v1
NEXT_PUBLIC_API_URL=http://localhost:5000/api/v1

# Stellar Network Configuration
# Use 'testnet' for development, 'public' for production
NEXT_PUBLIC_STELLAR_NETWORK=testnet

# Application Metadata
NEXT_PUBLIC_APP_NAME=Harvest Finance
NEXT_PUBLIC_APP_DESCRIPTION=Empowering smallholder farmers through blockchain financing.
